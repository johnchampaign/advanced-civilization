# Async-multiplayer configuration for the game server (src/server/http.ts).
# With NONE of these set, the server runs with a filesystem store (.data/games),
# no email, and no realtime — fine for local play.

# Base URL used to build shareable per-player invite links (and email links).
PUBLIC_BASE_URL=http://localhost:5173

# --- Supabase (production storage + realtime) ---
# Apply supabase/schema.sql to the project first. RLS is enabled with no policies,
# so only the SERVICE key (server-side) can read tokens/state; the anon key is for
# client Realtime only.
# SUPABASE_URL=https://YOURPROJECT.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key   # server only — never ship to client
# VITE_SUPABASE_URL=https://YOURPROJECT.supabase.co   # client (Realtime)
# VITE_SUPABASE_ANON_KEY=your-anon-key                # client (Realtime), safe to ship

# --- Email turn notifications (Resend) ---
# RESEND_API_KEY=your-resend-key
# MAIL_FROM=Advanced Civilization <noreply@yourdomain>

# Server port (default 8787) and filesystem store dir (default .data/games).
# PORT=8787
# DBF_DATA_DIR=.data/games
