# dependencies / build output
node_modules/
dist/
dist-ui/
*.tgz
package/

# downloaded + extracted source artifacts (re-creatable via scripts/; the
# committed game data lives in src/data/*.json). Anchored to the top-level dir
# so public/assets/ (the served board SVG) is NOT ignored.
/assets/

# runtime / secrets
.data/
.env
.dev.vars

# Board artwork is bring-your-own (extracted from the VASSAL module in the
# browser at runtime) -- never ship or redistribute the map images.
public/assets/map-main.svg
public/assets/map-western.svg
public/assets/map-eastern.svg
public/assets/images/map-main-labeled.svg
assets/civ.vmod
