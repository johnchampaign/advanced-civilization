{
  "name": "advanced-civilization",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Digital port of Avalon Hill's Advanced Civilization, built on digital-boardgame-framework.",
  "license": "MIT",
  "author": "John Champaign",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "extract": "node --experimental-strip-types scripts/extract-map.ts",
    "dev": "vite",
    "build:ui": "vite build",
    "serve": "tsc -p tsconfig.json && node dist/server/http.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "digital-boardgame-framework": "^0.31.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "sharp": "^0.35.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.0"
  }
}
